---
import LegalPage from '../components/LegalPage.astro'
import { termsContent } from '../data/legal'
import BaseLayout from '../layouts/BaseLayout.astro'
import { absoluteUrl } from '../data/site'

const locale = 'en'
const content = termsContent[locale]
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: content.title,
  description: content.description,
  url: absoluteUrl('/terms/'),
  dateModified: '2026-06-09'
}
---

<BaseLayout title={`${content.title} | WODIQ`} description={content.description} locale={locale} path="/terms/" alternatePath="/nl/terms/" schema={[schema]}>
  <LegalPage locale={locale} content={content} />
</BaseLayout>
